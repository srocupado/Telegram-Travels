BOT_TOKEN=replace_me_with_botfather_token
SERPAPI_KEY=replace_me_with_serpapi_key
ACCESS_PASSWORD=replace_me_with_a_strong_password

# Provedor de IA. Opções: anthropic | openai | gemini. Default: anthropic.
# Só preencha a chave do provider que você for usar; as outras podem ficar vazias.
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=replace_me_with_anthropic_key
OPENAI_API_KEY=
GEMINI_API_KEY=

# Modelos por tier (fast = parser/chat/alertas/ping, slow = roteiro/compras/seguir)
# Anthropic
HAIKU_MODEL=claude-haiku-4-5
SONNET_MODEL=claude-sonnet-4-6
# OpenAI (ajuste os IDs conforme disponibilidade)
OPENAI_FAST_MODEL=gpt-5-mini
OPENAI_SLOW_MODEL=gpt-5
# Gemini (ajuste os IDs conforme disponibilidade)
GEMINI_FAST_MODEL=gemini-2.5-flash
GEMINI_SLOW_MODEL=gemini-2.5-pro

DATABASE_PATH=/data/travels.db
LOG_LEVEL=INFO
LOG_JSON=true
SCHEDULER_TICK_SECONDS=3600
WATCH_CHECK_INTERVAL_HOURS=24
ALERT_COOLDOWN_HOURS=12

# --- Trânsito (digest casa→trabalho 07:20 BRT seg-sex) ---
# Necessário para /trafego_now e /trafego_on. Sem isso, a feature fica inativa.
# Obtenha a chave em https://console.cloud.google.com/google/maps-apis
GOOGLE_MAPS_API_KEY=
# Coordenadas em "lat,lng" (use ponto, não vírgula decimal).
HOME_COORDS=
WORK_COORDS=
# Opcional: cole a URL do Google Maps da sua rota preferida. O bot extrai
# os waypoints intermediários e força a Directions API a passar por eles.
# Aceita short links (maps.app.goo.gl) e URLs completas (/maps/dir/...).
ROUTE_GOOGLE_MAPS_URL=
# Kill-switch do digest diário. /trafego_now continua funcionando.
TRAFFIC_DIGEST_ENABLED=true
TRAFFIC_HOUR=7
TRAFFIC_MINUTE=20
# Dica: pra a mensagem chegar perto de 07:20, baixe SCHEDULER_TICK_SECONDS=600.
